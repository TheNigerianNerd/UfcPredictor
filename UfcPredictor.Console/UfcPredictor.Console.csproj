<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\UfcPredictor.Lib\UfcPredictor.Lib.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Spectre.Console" Version="0.54.0" />
  </ItemGroup>

  <Target Name="RunTestsBeforeBuild" BeforeTargets="Build" Condition="'$(Configuration)' == 'Debug'">
    <Message Importance="High" Text="[TDD] Running UfcPredictor.Tests before build..." />
    <Exec Command="dotnet test ../UfcPredictor.Tests/UfcPredictor.Tests.csproj" />
</Target>
</Project>
